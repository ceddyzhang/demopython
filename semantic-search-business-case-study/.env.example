# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.
# Separate params (not a single URI) so special characters in the password don't need percent-encoding.

SUPABASE_DB_HOST=aws-1-us-east-2.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-password-here

# Google Gemini embedding API key
GEMINI_API_KEY=your-gemini-api-key-here
